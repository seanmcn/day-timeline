# Day Timeline Environment Variables
# Copy this file to .env.local and fill in your values
# These will be set as Amplify sandbox secrets

# Google OAuth credentials (required for Google Calendar & Tasks integration)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Frontend needs the client ID too (public, included in OAuth redirect URL)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
